# Rapidoss - Variables d'environnement

# API Keys (à configurer en production)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# Backend API (à configurer quand le backend sera prêt)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Mobile Money (à configurer pour les paiements)
NEXT_PUBLIC_MPESA_API_KEY=""
NEXT_PUBLIC_ORANGE_MONEY_API_KEY=""

# Firebase (optionnel pour notifications push)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Environnement
NODE_ENV="development"
